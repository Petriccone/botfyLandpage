{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/botfy-icon.svg",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard/:path*",
      "destination": "https://bnbbot.vercel.app/dashboard/:path*"
    },
    {
      "source": "/login",
      "destination": "https://bnbbot.vercel.app/login"
    },
    {
      "source": "/register",
      "destination": "https://bnbbot.vercel.app/register"
    },
    {
      "source": "/api/:path*",
      "destination": "https://bnbbot.vercel.app/api/:path*"
    },
    {
      "source": "/((?!api|dashboard|login|register).*)",
      "destination": "/index.html"
    }
  ]
}